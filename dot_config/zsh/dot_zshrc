# Function to set WORK_ITEM_KEY
work() {
    if [ -z "$1" ]; then
        # No argument provided - show current value
        if [ -z "$WORK_ITEM_KEY" ]; then
            echo "WORK_ITEM_KEY is not set"
        else
            echo "WORK_ITEM_KEY=$WORK_ITEM_KEY"
        fi
    else
        # Argument provided - set and export the variable and add FRONT- in front
        export WORK_ITEM_KEY="FRONT-$1"
        echo "WORK_ITEM_KEY set to:$WORK_ITEM_KEY"
    fi
}

# Function to show jiratui issue metadata and update fields
jira_update() {
    local issue_key="${1:-$WORK_ITEM_KEY}"
    
    if [ -z "$issue_key" ]; then
        echo "Error: No work item key provided. Set WORK_ITEM_KEY or pass it as an argument."
        echo "Usage: jira_update [WORK_ITEM_KEY]"
        return 1
    fi
    
    echo "Showing metadata for $issue_key..."
    echo "============================================================"
    jiratui issues metadata "$issue_key"
    echo ""
    echo "============================================================"
    echo "Update options:"
    echo "1) Status (requires status ID)"
    echo "2) Assignee (requires account ID)"
    echo "3) Priority (requires priority ID)"
    echo "4) Summary/Title"
    echo "5) Add Comment"
    echo "6) Skip update"
    echo ""
    
    read "choice?Select option (1-6): "
    
    case "$choice" in
        1)
            echo ""
            echo "To find status IDs, check the metadata above or run: jiratui issues update $issue_key --meta"
            read "status_id?Enter status ID: "
            if [ -n "$status_id" ]; then
                jiratui issues update "$issue_key" --status-id "$status_id"
            else
                echo "No status ID provided. Update cancelled."
            fi
            ;;
        2)
            echo ""
            echo "To find assignee account IDs, check the metadata above or search users."
            read "account_id?Enter assignee account ID (or leave empty to unassign): "
            if [ -n "$account_id" ]; then
                jiratui issues update "$issue_key" --assignee-account-id "$account_id"
            else
                jiratui issues update "$issue_key" --assignee-account-id ""
            fi
            ;;
        3)
            echo ""
            echo "To find priority IDs, check the metadata above or run: jiratui issues update $issue_key --meta"
            read "priority_id?Enter priority ID: "
            if [ -n "$priority_id" ]; then
                jiratui issues update "$issue_key" --priority-id "$priority_id"
            else
                echo "No priority ID provided. Update cancelled."
            fi
            ;;
        4)
            echo ""
            read "summary?Enter new summary/title: "
            if [ -n "$summary" ]; then
                jiratui issues update "$issue_key" --summary "$summary"
            else
                echo "No summary provided. Update cancelled."
            fi
            ;;
        5)
            echo ""
            read "comment?Enter comment message: "
            if [ -n "$comment" ]; then
                jiratui comments add "$issue_key" "$comment"
            else
                echo "No comment provided. Update cancelled."
            fi
            ;;
        6)
            echo "Update cancelled."
            ;;
        *)
            echo "Invalid option. Update cancelled."
            ;;
    esac
}

# Alias for jira_update
alias jupdate='jira_update'

# Function to quickly add a comment to a jiratui issue
jira_comment() {
    local issue_key="${1:-$WORK_ITEM_KEY}"
    local comment="${2}"
    
    if [ -z "$issue_key" ]; then
        echo "Error: No work item key provided. Set WORK_ITEM_KEY or pass it as an argument."
        echo "Usage: jira_comment [WORK_ITEM_KEY] 'COMMENT_MESSAGE'"
        return 1
    fi
    
    if [ -z "$comment" ]; then
        echo "Error: No comment message provided."
        echo "Usage: jira_comment [WORK_ITEM_KEY] 'COMMENT_MESSAGE'"
        return 1
    fi
    
    jiratui comments add "$issue_key" "$comment"
}

# Alias for jira_comment
alias jcomment='jira_comment'

# Function to fetch summary, metadata, and comments for a jiratui issue
jfetch() {
    local issue_key="${1:-$WORK_ITEM_KEY}"
    
    if [ -z "$issue_key" ]; then
        echo "Error: No work item key provided. Set WORK_ITEM_KEY or pass it as an argument."
        echo "Usage: jfetch [WORK_ITEM_KEY]"
        return 1
    fi
    
    echo "============================================================"
    echo "Fetching information for: $issue_key"
    echo "============================================================"
    echo ""
    
    # Fetch summary from search
    echo "📋 SUMMARY"
    echo "────────────────────────────────────────────────────────────"
    jiratui issues search -k "$issue_key" -l 1 2>/dev/null || echo "Could not fetch summary"
    echo ""
    
    # Fetch metadata
    echo "📊 METADATA"
    echo "────────────────────────────────────────────────────────────"
    jiratui issues metadata "$issue_key"
    echo ""
    
    # Fetch comments
    echo "?? COMMENTS"
    echo "???????????????????????????????????????????????????????????????"
    jiratui comments list "$issue_key" 2>/dev/null || echo "No comments found or could not fetch comments"
    echo ""
    
    echo "============================================================"
}

# Function to open a Jira issue link in the browser
jopen() {
    local issue_key="${1:-$WORK_ITEM_KEY}"
    
    if [ -z "$issue_key" ]; then
        echo "Error: No work item key provided. Set WORK_ITEM_KEY or pass it as an argument."
        echo "Usage: jopen [WORK_ITEM_KEY]"
        return 1
    fi
    
    # Try to get Jira base URL from config file, or use environment variable
    local jira_base_url="${JIRA_BASE_URL}"
    
    if [ -z "$jira_base_url" ]; then
        # Try to extract from jiratui config file
        local config_file="$HOME/.config/jiratui/config.yaml"
        if [ -f "$config_file" ]; then
            jira_base_url=$(grep -E "^jira_api_base_url:" "$config_file" | sed 's/^jira_api_base_url:[[:space:]]*//' | tr -d '"' | tr -d "'")
        fi
    fi
    
    # Fallback to default if still not found
    if [ -z "$jira_base_url" ]; then
        jira_base_url="https://redventures.atlassian.net"
    fi
    
    # Construct the Jira issue URL
    local jira_url="${jira_base_url}/browse/${issue_key}"
    
    echo "Opening: $jira_url"
    open "$jira_url"
}
