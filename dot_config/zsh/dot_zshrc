# Function to open current directory in Finder, reusing existing window if open
oo() {
    local target="${1:-.}"
    local abs_path=$(cd "$target" && pwd)
    
    # Use AppleScript to check if Finder has windows and reuse them
    osascript <<EOF 2>/dev/null
tell application "Finder"
    if (count of windows) > 0 then
        set target of front window to POSIX file "$abs_path"
        activate
    else
        open POSIX file "$abs_path"
        activate
    end if
end tell
EOF
    
    # Fallback to standard open if AppleScript fails
    if [ $? -ne 0 ]; then
        open "$target"
    fi
}

